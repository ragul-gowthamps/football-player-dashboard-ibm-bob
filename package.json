{
  "name": "player-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:react":  "yarn --cwd react-app install",
    "start:react":    "yarn --cwd react-app start:dev",
    "start:python":   "python -m streamlit run python-app/streamlit_app.py --server.port 8501",
    "setup":          "npm run install:react",
    "start:all":      "concurrently --names \"REACT,PYTHON\" --prefix-colors \"cyan,magenta\" \"npm run start:react\" \"npm run start:python\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
